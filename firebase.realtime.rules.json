{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "name": {
          ".validate": "newData.isString()"
        },
        "email": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "role": {
          ".validate": "newData.val() === 'user' || newData.val() === 'admin'"
        },
        "createdAt": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "lastLogin": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "grade": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "referralSource": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "hosaEvents": {
          ".validate": "newData.hasChildren() || !newData.exists()",
          "$index": {
            ".validate": "$index.matches(/^[0-9]+$/) && newData.isString()"
          }
        },
        "hosaEventsOther": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "experienceLevel": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "goal": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "charterOrganization": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "questionsPerSession": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "onboardingCompleted": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        },
        "settings": {
          "accuracyGoal": {
            ".validate": "newData.isNumber() && newData.val() >= 50 && newData.val() <= 100"
          },
          "sessionQuestionLimit": {
            ".validate": "newData.isNumber() && (newData.val() == 10 || newData.val() == 25 || newData.val() == 50 || newData.val() == 100) || (newData.isString() && newData.val() == 'unlimited')"
          },
          "showExplanationTime": {
            ".validate": "newData.isBoolean()"
          },
          "redemptionRoundEnabled": {
            ".validate": "newData.isBoolean()"
          },
          "$otherSetting": {
            ".validate": false
          }
        },
        "events": {
          "$eventId": {
            "wrongQuestions": {
              "$index": {
                ".validate": "$index.matches(/^[0-9]+$/) && newData.isNumber() && newData.val() >= 0"
              }
            },
            "completedQuestions": {
              "$index": {
                ".validate": "$index.matches(/^[0-9]+$/) && newData.isNumber() && newData.val() >= 0"
              }
            },
            "sessions": {
              "$sessionId": {
                "sessionId": { ".validate": "newData.isString() && newData.val().length > 0" },
                "sessionType": { ".validate": "newData.isString() && (newData.val() == 'practice' || newData.val() == 'timed')" },
                "event": { ".validate": "newData.isString() && newData.val().length > 0" },
                "startTimestamp": { ".validate": "newData.isString() && newData.val().length > 0" },
                "endTimestamp": { ".validate": "newData.isString() || !newData.exists()" },
                "totalThinkTime": { ".validate": "newData.isNumber() && newData.val() >= 0" },
                "totalExplanationTime": { ".validate": "newData.isNumber() && newData.val() >= 0" },
                "totalQuestions": { ".validate": "newData.isNumber() && newData.val() >= 0" },
                "correctCount": { ".validate": "newData.isNumber() && newData.val() >= 0" },
                "accuracy": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
                "attempts": { ".validate": "newData.isString()" },
                "startTime": { ".validate": "newData.isString() || !newData.exists()" },
                "endTime": { ".validate": "newData.isString() || !newData.exists()" },
                "eventId": { ".validate": "newData.isString() || !newData.exists()" },
                "$otherSessionDetail": {
                  ".validate": "newData.isNumber() || newData.isString() || newData.isBoolean() || !newData.exists()"
                }
              }
            },
            "stats": {
              "questionsAnswered": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              },
              "accuracy": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
              },
              "$otherEventStat": {
                ".validate": "newData.isNumber() || newData.isString() || newData.isBoolean()"
              }
            }
          }
        },
        "generalStats": {
          "questionsAnswered": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "accuracy": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
          },
          "bestEvent": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "$otherGeneralStat": {
            ".validate": "newData.isNumber() || newData.isString() || newData.isBoolean()"
          }
        },
        "currentSession": {
          ".validate": "newData.val() == null || newData.hasChildren(['sessionId', 'sessionType', 'event', 'startTimestamp', 'attempts'])"
        }
      }
    },
    "event_requests": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$requestId": {
        ".write": "auth != null"
      }
    },
    "question_submissions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$submissionId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('submittedBy').child('uid').val() === auth.uid)",
        ".write": "auth != null"
      }
    },
    "question_reports": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$reportId": {
        ".write": "auth != null"
      }
    },
    "feedback_submissions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$feedbackId": {
        ".write": "auth != null"
      }
    },
    "admin_stats": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$node": {
        ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren() || newData.val() == null"
      }
    }
  }
}
